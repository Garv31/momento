# Momento – Environment Variables
# Copy this file to .env.local and fill in the values.

# MongoDB connection string
# Leave empty to use an in-memory database (great for development, data lost on restart)
# Set to your own MongoDB Atlas / self-hosted URI for persistent storage:
#   mongodb+srv://<user>:<password>@cluster.mongodb.net/momento
MONGODB_URI=

# NextAuth
NEXTAUTH_SECRET=change-me-to-a-random-secret
NEXTAUTH_URL=http://localhost:3000
